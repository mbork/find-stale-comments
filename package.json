{
  "name": "find-stale-comments",
  "version": "0.0.1",
  "description": "A script to be used in pre-commit hook to prevent changing code without changing the corresponding comment",
  "license": "MIT",
  "author": "Marcin mbork Borkowski",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "test": "node --test",
    "fixtures": "node tests/generate-fixtures.ts",
    "lint": "eslint .",
    "typecheck": "tsgo",
    "coverage": "npx c8 node --test",
    "coverage-report": "npx c8 --reporter=html node --test && xdg-open coverage/index.html"
  },
  "dependencies": {
    "parse-diff": "^0.11.1",
    "simple-git": "^3.32.3"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.3.5",
    "@typescript/native-preview": "^7.0.0-dev.20260316.1",
    "c8": "^11.0.0",
    "eslint": "^10.0.3",
    "typescript-eslint": "^8.57.0"
  }
}
